# ──────────────────────────────────────────────────────────────
# TaktEule Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# ── Model Provider ──────────────────────────────────────────
# Choose one: azure_foundry | openai | anthropic
#
# All providers persist conversation history:
# - azure_foundry: stored in Azure Agent Service
# - openai / anthropic: stored in a Cosmos DB "messages" container
MODEL_PROVIDER=azure_foundry

# ── Azure AI Foundry (when MODEL_PROVIDER=azure_foundry) ────
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT_NAME=gpt-4o

# ── OpenAI Direct (when MODEL_PROVIDER=openai) ─────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# ── Anthropic (when MODEL_PROVIDER=anthropic) ───────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Azure Cosmos DB (required) ──────────────────────────────
COSMOS_URL=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-key>
COSMOS_DB=takteule
# Or use a full connection string instead:
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://...;AccountKey=...;

# ── Email encryption ────────────────────────────────────────
# Used to encrypt SMTP passwords stored in Cosmos DB.
# If not set, COSMOS_KEY is used as a fallback to derive the key.
# EMAIL_ENCRYPTION_KEY=<some-random-secret-string>
